  {
    "id": 5,
    "title": "Scoring: Bonus Points (Tai)",
    "content": "In Taiwanese Mahjong, winning hands earn bonus points called Tai. The more Tai you have, the more you win!",
    "details": [
      "All Triplets (+4 Tai) — A winning hand made entirely of Pongs and Kongs, no Chows allowed.",
      "Full Flush (+4 Tai) — A winning hand using only one suit (Bamboo, Circle, or Character), no Honor tiles.",
      "Concealed Hand (+1 Tai) — You win without claiming any discarded tiles. All melds formed by drawing tiles yourself.",
      "Self-Draw (+1 Tai) — You draw the winning tile yourself from the wall. All three other players pay you!"
    ]
  },
  {
    "id": 6,
    "title": "Review: Tiles & Melds",
    "is_review": true,
    "content": "Let's review what you've learned before the practice section.",
    "sections": [
      {
        "heading": "Tile Types",
        "points": [
          "Bamboo, Circles, Characters 9 each, x4 = 36 per suit",
          "Winds (East/South/West/North) x4 each = 16. No Chows, only Pongs & Kongs.",
          "Dragons (Red/Green/White) x4 each = 12. No Chows, only Pongs & Kongs.",
          "Flowers/Seasons 8 total, each x1. Reveal & draw replacement."
        ]
      },
      {
        "heading": "Melds",
        "points": [
          "Pong = 3 identical tiles",
          "Kong = 4 identical tiles",
          "Chow = 3 consecutive tiles, same suit only from player ahead",
          "Eyes = 2 identical tiles (pair)"
        ]
      },
      {
        "heading": "Winning & Scoring",
        "points": [
          "Win (Hu) = 5 melds + 1 pair (Eyes)",
          "Ready Hand = one tile away from winning",
          "All Triplets = +4 Tai | Full Flush = +4 Tai",
          "Concealed Hand = +1 Tai | Self-Draw = +1 Tai"
        ]
      }
    ]
  }
