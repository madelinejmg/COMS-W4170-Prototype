  {
    "id": 4,
    "title": "Review: Tiles & Melds",
    "is_review": true,
    "content": "Let's review what you've learned before the practice section.",
    "sections": [
      {
        "heading": "Tile Types",
        "points": [
          "Bamboo, Circles, Characters — 9 values each × 4 copies = 36 tiles per suit",
          "Winds (East / South / West / North) — Pong or Kong only, no Chow",
          "Dragons (Red / Green / White) — Pong or Kong only, no Chow",
          "Flowers & Seasons — 8 tiles, each unique. Reveal immediately and draw a replacement tile."
        ]
      },
      {
        "heading": "Melds",
        "points": [
          "Pong — 3 identical tiles (claim from any player)",
          "Kong — 4 identical tiles (claim from any player, then draw a replacement tile)",
          "Chow — 3 consecutive tiles, same suit, claimed from the player directly ahead only",
          "Eyes — 1 pair of identical tiles, required in every winning hand"
        ]
      },
      {
        "heading": "Winning (Hu)",
        "points": [
          "5 melds + 1 pair (Eyes) = 17 tiles total",
          "Ready Hand = one tile away from winning",
          "Plain Hu (0 Tai): discarder pays the winner the base amount",
          "Self-Draw: all three opponents each pay the winner the full amount"
        ]
      },
      {
        "heading": "Tai Bonuses",
        "points": [
          "Self-Draw — +1 Tai: draw the winning tile yourself",
          "Concealed Hand — +1 Tai: no claimed tiles at all, all 16 tiles drawn yourself",
          "Concealed Self-Draw — +3 Tai: Concealed Hand AND Self-Draw combined",
          "All Triplets — +4 Tai: all melds are Pongs or Kongs, no Chows",
          "Full Flush — +8 Tai: all tiles from one suit only, no honor tiles",
          "Big Three Dragons — +8 Tai: Pong all three Dragon tiles",
          "Big Four Winds — +8 Tai: Pong all four Wind tiles",
          "Bonuses stack — e.g. All Triplets + Self-Draw = 5 Tai"
        ]
      }
    ]
  }
]